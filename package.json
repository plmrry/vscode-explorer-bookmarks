{
  "name": "vscode-explorer-bookmarks",
  "displayName": "Explorer Bookmarks",
  "version": "2026.2.272306",
  "description": "Add bookmarks to the Explorer panel",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/plmrry/vscode-explorer-bookmarks"
  },
  "publisher": "paul-murray",
  "main": "./ts-out/extension.js",
  "types": "./ts-out/extension.d.ts",
  "files": [
    "bookmark-icon.png",
    "example.png",
    "LICENSE.md",
    "package.json",
    "README.md",
    "src",
    "ts-out",
    "tsconfig.json"
  ],
  "scripts": {
    "biome": "biome check --write --unsafe .",
    "precompile": "npm run biome",
    "compile": "tsgo --build",
    "prepackage": "npm run compile",
    "package": "vsce package",
    "prepublish": "npm run package",
    "publish": "vsce publish patch"
  },
  "contributes": {
    "commands": [
      {
        "command": "explorerBookmarks.refresh",
        "title": "Bookmarks: Refresh Bookmarks",
        "icon": "$(refresh)"
      },
      {
        "command": "explorerBookmarks.addBookmark",
        "title": "Bookmarks: Add to Bookmarks",
        "icon": "$(bookmark)"
      },
      {
        "command": "explorerBookmarks.removeBookmark",
        "title": "Bookmarks: Remove from Bookmarks",
        "icon": "$(trash)"
      },
      {
        "command": "explorerBookmarks.setEmoji",
        "title": "Bookmarks: Set Emoji",
        "icon": "$(smiley)"
      }
    ],
    "configuration": {
      "title": "Explorer Bookmarks",
      "properties": {
        "explorerBookmarks.bookmarks": {
          "type": "array",
          "scope": "resource",
          "default": [],
          "description": "Bookmarks displayed in the Explorer Bookmarks view.",
          "items": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "description": "Absolute path to a file or folder."
              },
              "icon": {
                "type": "string",
                "description": "Optional codicon name for the bookmark icon."
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "explorerBookmarks.refresh",
          "when": "view == explorerBookmarks",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "explorerBookmarks.addBookmark",
          "group": "2_workspace"
        }
      ],
      "view/item/context": [
        {
          "command": "explorerBookmarks.setEmoji",
          "when": "view == explorerBookmarks && viewItem == bookmark",
          "group": "inline"
        },
        {
          "command": "explorerBookmarks.removeBookmark",
          "when": "view == explorerBookmarks && viewItem == bookmark",
          "group": "inline"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "explorerBookmarks",
          "name": "Bookmarks",
          "icon": "bookmark-icon.png"
        }
      ]
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "24",
    "@types/vscode": "^1.109",
    "@typescript/native-preview": "^7.0.0-dev.20260227.1",
    "@vscode/vsce": "latest"
  },
  "packageManager": "npm@11.11.0+sha512.f36811c4aae1fde639527368ae44c571d050006a608d67a191f195a801a52637a312d259186254aa3a3799b05335b7390539cf28656d18f0591a1125ba35f973",
  "engines": {
    "node": "24.x",
    "vscode": "^1.109.5"
  },
  "icon": "bookmark-icon.png",
  "pricing": "Free",
  "vsce": {
    "out": "vsix-file",
    "githubBranch": "main",
    "noDependencies": true
  }
}
