{
  "name": "vscode-explorer-bookmarks",
  "displayName": "Explorer Bookmarks",
  "version": "0.5.0",
  "description": "Add bookmarks to the Explorer panel",
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/plmrry/vscode-explorer-bookmarks"
  },
  "publisher": "paul-murray",
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "pretest": "pnpm run check && pnpm run compile",
    "vscode:prepublish": "pnpm run compile",
    "package": "vsce package",
    "publish": "vsce publish",
    "vsce": "vsce"
  },
  "contributes": {
    "commands": [
      {
        "command": "explorerBookmarks.refresh",
        "title": "Bookmarks: Refresh Bookmarks",
        "icon": "$(refresh)"
      },
      {
        "command": "explorerBookmarks.addBookmark",
        "title": "Bookmarks: Add to Bookmarks",
        "icon": "$(bookmark)"
      },
      {
        "command": "explorerBookmarks.removeBookmark",
        "title": "Bookmarks: Remove from Bookmarks",
        "icon": "$(trash)"
      },
      {
        "command": "explorerBookmarks.setEmoji",
        "title": "Bookmarks: Set Emoji",
        "icon": "$(smiley)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "explorerBookmarks.refresh",
          "when": "view == explorerBookmarks",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "explorerBookmarks.addBookmark",
          "group": "2_workspace"
        }
      ],
      "view/item/context": [
        {
          "command": "explorerBookmarks.setEmoji",
          "when": "view == explorerBookmarks && viewItem == bookmark",
          "group": "inline"
        },
        {
          "command": "explorerBookmarks.removeBookmark",
          "when": "view == explorerBookmarks && viewItem == bookmark",
          "group": "inline"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "explorerBookmarks",
          "name": "Bookmarks",
          "icon": "bookmark-icon.png"
        }
      ]
    },
    "configuration": {
      "title": "Explorer Bookmarks",
      "properties": {
        "explorerBookmarks.bookmarks": {
          "type": "array",
          "scope": "resource",
          "default": [],
          "description": "Bookmarks displayed in the Explorer Bookmarks view.",
          "items": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string",
                "description": "Absolute path to a file or folder."
              },
              "icon": {
                "type": "string",
                "description": "Optional codicon name for the bookmark icon."
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "24",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "latest",
    "typescript": "latest"
  },
  "engines": {
    "node": "24.x",
    "vscode": "^1.107.0"
  },
  "icon": "bookmark-icon.png"
}
